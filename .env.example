DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/gradeagent
REDIS_URL=redis://localhost:6379/0
TEMPORAL_ENABLED=false
TEMPORAL_TARGET=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=gradeagent-grading
MODEL_ROUTER_PROVIDER=ollama
MODEL_ROUTER_SIMPLE_MODEL=qwen3.5:4b
MODEL_ROUTER_STANDARD_MODEL=qwen3.5:9b
MODEL_ROUTER_COMPLEX_MODEL=qwen3.5:9b
BROWSER_AGENT_PROVIDER=ollama
BROWSER_AGENT_MODEL=qwen3.5:9b
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_TIMEOUT_SECONDS=120
OLLAMA_KEEP_ALIVE=15m
OLLAMA_GRADING_NUM_CTX=6144
OLLAMA_GRADING_NUM_PREDICT=512
OLLAMA_BROWSER_NUM_CTX=8192
OLLAMA_BROWSER_NUM_PREDICT=384
OLLAMA_SIMPLE_REASONING_MODE=off
OLLAMA_STANDARD_REASONING_MODE=off
OLLAMA_COMPLEX_REASONING_MODE=high
BROWSER_AGENT_FLASH_MODE=true
BROWSER_AGENT_USE_THINKING=false
BROWSER_AGENT_MAX_ACTIONS_PER_STEP=2
BROWSER_AGENT_MAX_HISTORY_ITEMS=6
BROWSER_AGENT_VISION_DETAIL_LEVEL=low
BROWSER_AGENT_LLM_TIMEOUT_SECONDS=90
GOOGLE_API_FREE_TIER_ONLY=true
GOOGLE_API_FREE_TIER_FALLBACK_MODEL=gemini-3-flash-preview
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
BROWSER_HEADLESS=false
BROWSER_DEBUG_PORT=9222
BROWSER_USE_SYSTEM_CHROME=false
BROWSER_ENABLE_DEFAULT_EXTENSIONS=false
BROWSER_DIRECT_PERSISTENT_PROFILE=true
BROWSER_CHROME_PROFILE_DIRECTORY=Default
BROWSER_PERSISTENT_PROFILE_DIR=artifacts/browser/browser-use-user-data-dir-gradeagent
BROWSER_START_URL=https://www.sanomapro.fi/auth/login/
BROWSER_CLEANUP_STALE_AFTER_SECONDS=3600
BROWSER_MAX_SAVED_SCREENSHOTS=3
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
