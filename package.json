{
  "name": "gradeagent",
  "private": true,
  "scripts": {
    "cli": ".\\.venv\\Scripts\\gradeagent",
    "dev:api": ".\\.venv\\Scripts\\python -m uvicorn app.main:app --reload --app-dir apps/api",
    "worker:api": ".\\.venv\\Scripts\\python apps/api/app/workflows/worker.py",
    "dev:web": "npm --prefix apps/web run dev",
    "build:web": "npm --prefix apps/web run build",
    "lint:web": "npm --prefix apps/web run lint",
    "typecheck:web": "npm --prefix apps/web run typecheck",
    "install:web": "npm --prefix apps/web install",
    "test:api": "python -m pytest apps/api/tests"
  }
}
